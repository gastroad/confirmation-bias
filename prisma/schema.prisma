generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Outlet {
  id      String  @id
  name    String
  domain  String
  leaning String  // "left" | "center_left" | "center" | "center_right" | "right" | "unknown"

  articles Article[]
}

model Cluster {
  id                  String   @id @default(uuid())
  representativeTitle String
  summary             String?
  centroidJson        String?  // JSON.stringify(number[]) — 512-dim normalized vector
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  articles Article[]

  @@index([updatedAt]) // 목록 커서 페이지네이션(orderBy updatedAt desc)
}

model Article {
  id            String   @id @default(uuid())
  title         String
  description   String?
  url           String   @unique
  publishedAt   DateTime
  embeddingJson String?  // JSON.stringify(number[]) — 512-dim normalized vector

  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  clusterId String?
  cluster   Cluster? @relation(fields: [clusterId], references: [id])

  createdAt DateTime @default(now())

  @@index([clusterId])            // 클러스터별 기사 로드
  @@index([outletId])             // 언론사 필터(some outletId in) · stats groupBy
  @@index([clusterId, outletId])  // 필터 + 집계 복합
}
